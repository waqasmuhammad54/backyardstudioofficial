# Backyard Studio Official — Environment Variables
# Copy to .env.local locally, and add ALL to Vercel: Settings → Environment Variables

# Resend (Email) — sign up free at https://resend.com
# Add & verify domain backyardstudioofficial.com → get API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase (Database) — sign up free at https://supabase.com
# Settings → API → Project URL + service_role key
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# Admin CRM Password — protects /admin page
ADMIN_PASSWORD=your-strong-admin-password-here

# Site URL
NEXT_PUBLIC_SITE_URL=https://www.backyardstudioofficial.com
