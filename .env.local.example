# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from: resend.com → API Keys
# Must verify backyardstudioofficial.com domain in Resend before emails send
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Database (Supabase) ─────────────────────────────────────────────────────
# Get from: app.supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Admin CRM Dashboard ─────────────────────────────────────────────────────
# Any strong password — used to login at /admin
ADMIN_PASSWORD=your_strong_password_here

# ─── Google Analytics 4 ──────────────────────────────────────────────────────
# Get from: analytics.google.com → Admin → Data Streams → your stream → Measurement ID
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Site URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.backyardstudioofficial.com
